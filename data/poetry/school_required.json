{
  "poems": [
    {
      "id": "schn-001",
      "title": "静夜思",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "李白", "nickname": "诗仙"},
      "content": ["床前明月光，", "疑是地上霜。", "举头望明月，", "低头思故乡。"],
      "translation": ["月光照在床前，", "让人怀疑是地上结了霜。", "抬起头望着天上的明月，", "低下头不禁思念起故乡。"],
      "annotation": [{"term": "床", "explanation": "指井台或窗前。"}, {"term": "疑", "explanation": "好像。"}, {"term": "举头", "explanation": "抬头。"}],
      "background": "此诗写于唐玄宗开元十四年，李白时年26岁，正在扬州。",
      "difficulty": 1,
      "tags": ["思乡", "月亮", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [
        {"id": "q-001-1", "type": "choice", "question": "《静夜思》的作者是谁？", "options": ["杜甫", "李白", "王维", "白居易"], "correctIndex": 1, "explanation": "李白是唐代伟大的浪漫主义诗人。"},
        {"id": "q-001-2", "type": "choice", "question": "“疑是地上霜”的“疑”是什么意思？", "options": ["怀疑", "好像", "疑问", "疑惑"], "correctIndex": 1, "explanation": "“疑”是“好像”的意思。"}
      ],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-002",
      "title": "春晓",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "孟浩然", "nickname": "诗狂"},
      "content": ["春眠不觉晓，", "处处闻啼鸟。", "夜来风雨声，", "花落知多少。"],
      "translation": ["春天睡得很香不知不觉天就亮了，", "醒来时到处都能听到鸟叫声。", "想起夜里听到的风雨声，", "不知道有多少花瓣被吹落了。"],
      "annotation": [{"term": "春晓", "explanation": "春天的早晨。"}, {"term": "闻", "explanation": "听到。"}],
      "background": "孟浩然是唐代著名的山水田园诗人，这首《春晓》是他最著名的作品之一。",
      "difficulty": 1,
      "tags": ["春天", "自然", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [
        {"id": "q-002-1", "type": "choice", "question": "《春晓》的作者是？", "options": ["李白", "孟浩然", "杜甫", "王维"], "correctIndex": 1, "explanation": "孟浩然是唐代山水田园诗人。"}
      ],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-003",
      "title": "登鹳雀楼",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "王之涣", "nickname": ""},
      "content": ["白日依山尽，", "黄河入海流。", "欲穷千里目，", "更上一层楼。"],
      "translation": ["太阳沿着山坡渐渐西沉，", "黄河水向着大海奔流。", "要想看到更远的地方，", "就要再登上一层楼。"],
      "annotation": [{"term": "鹳雀楼", "explanation": "楼名，在今山西永济。"}, {"term": "穷", "explanation": "尽，达到极点。"}],
      "background": "王之涣是唐代边塞诗人，这首诗写出了登楼远望的壮阔景象。",
      "difficulty": 1,
      "tags": ["登楼", "黄河", "励志", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [
        {"id": "q-003-1", "type": "choice", "question": "“欲穷千里目”的“穷”是什么意思？", "options": ["贫穷", "穷尽", "穷困", "尽头"], "correctIndex": 1, "explanation": "“穷”是“尽、看完”的意思。"}
      ],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-004",
      "title": "望庐山瀑布",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "李白", "nickname": "诗仙"},
      "content": ["日照香炉生紫烟，", "遥看瀑布挂前川。", "飞流直下三千尺，", "疑是银河落九天。"],
      "translation": ["太阳照在香炉峰上，峰顶云雾缭绕呈现出紫色，", "远远望去，瀑布就像一条白绢挂在山前。", "水流飞快地从高处直泻而下，大约有三千尺高，", "让人怀疑是银河从天上落到了人间。"],
      "annotation": [{"term": "香炉", "explanation": "指香炉峰。"}, {"term": "紫烟", "explanation": "紫色的云雾。"}, {"term": "九天", "explanation": "指天的最高处。"}],
      "background": "李白游览庐山时写下的千古名作，描写了庐山瀑布的壮丽景象。",
      "difficulty": 2,
      "tags": ["庐山", "瀑布", "山水", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [
        {"id": "q-004-1", "type": "choice", "question": "《望庐山瀑布》的作者是？", "options": ["杜甫", "李白", "王维", "孟浩然"], "correctIndex": 1, "explanation": "李白是唐代浪漫主义诗人。"}
      ],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-005",
      "title": "绝句",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "杜甫", "nickname": "诗圣"},
      "content": ["两个黄鹂鸣翠柳，", "一行白鹭上青天。", "窗含西岭千秋雪，", "门泊东吴万里船。"],
      "translation": ["两只黄鹂鸟在翠绿的柳树上欢快地鸣叫，", "一行白鹭排成整齐的队列飞向蓝天。", "从窗口望去，可以看见西岭千年不化的积雪，", "门前停泊着来自东吴行程万里的船只。"],
      "annotation": [{"term": "黄鹂", "explanation": "一种黄色的鸟。"}, {"term": "白鹭", "explanation": "一种白色的鸟。"}, {"term": "西岭", "explanation": "指成都西边的雪山。"}],
      "background": "这首诗是杜甫在成都草堂时所作，描写了草堂周围的美丽春景。",
      "difficulty": 2,
      "tags": ["春天", "景色", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-006",
      "title": "悯农（其一）",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "李绅", "nickname": ""},
      "content": ["春种一粒粟，", "秋收万颗子。", "四海无闲田，", "农夫犹饿死。"],
      "translation": ["春天种下一粒谷子，", "秋天可以收获万颗粮食。", "全天下没有闲置的田地，", "可农民还是被饿死了。"],
      "annotation": [{"term": "粟", "explanation": "谷子，这里指粮食的种子。"}, {"term": "四海", "explanation": "全天下。"}, {"term": "闲田", "explanation": "闲置的田地。"}],
      "background": "李绅是中唐诗人，这首诗深刻揭露了封建社会农民受剥削的残酷现实。",
      "difficulty": 1,
      "tags": ["农民", "社会", "同情", "小学必背"],
      "imageUrl": "",
      "relatedIds": [],
      "questions": [
        {"id": "q-006-1", "type": "choice", "question": "“农夫犹饿死”中“犹”是什么意思？", "options": ["仍然", "犹豫", "犹如", "犹豫不决"], "correctIndex": 0, "explanation": "“犹”是“仍然、还是”的意思。"}
      ],
      "schoolLevel": "primary"
    },
    {
      "id": "schn-007",
      "title": "枫桥夜泊",
      "category": "shi",
      "dynasty": "唐",
      "author": {"name": "张继", "nickname": ""},
      "content": ["月落乌啼霜满天，", "江枫渔火对愁眠。", "姑苏城外寒山寺，", "夜半钟声到客船。"],
      "translation": ["月亮落下去了，乌鸦在啼叫，寒霜弥漫满天，", "面对着江边的枫树和渔火，怀着忧愁入睡。", "姑苏城外寒山寺里，", "半夜的钟声传到了客船上。"],
      "annotation": [{"term": "枫桥", "explanation": "桥名，在今苏州。"}, {"term": "姑苏", "explanation": "苏州的别称。"}, {"term": "寒山寺", "explanation": "寺庙名，在苏州。"}],
      "background": "张继在经过苏州时，写下了这首描写江南水乡夜景的名作。",
      "difficulty": 2,
      "tags": ["夜景", "思乡", "江南", "小学必背"],
      "imageUrl": "",
